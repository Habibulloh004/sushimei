APP_NAME=sushimei-backend
APP_ENV=development
APP_PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sushimei?sslmode=disable
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1m
# Multiple origins separated by comma for customer (3000), admin (3001), staff (3002)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
