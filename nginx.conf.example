# Nginx Configuration for Sushimei
# Place this in /etc/nginx/sites-available/sushimei.conf
# Then symlink: ln -s /etc/nginx/sites-available/sushimei.conf /etc/nginx/sites-enabled/

# Upstream definitions
upstream customer_app {
    server 127.0.0.1:3000;
}

upstream admin_app {
    server 127.0.0.1:3001;
}

upstream staff_app {
    server 127.0.0.1:3002;
}

upstream backend_api {
    server 127.0.0.1:8080;
}

# Customer app - sushimei.uz
server {
    listen 80;
    listen [::]:80;
    server_name sushimei.uz www.sushimei.uz;

    # Redirect HTTP to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name sushimei.uz www.sushimei.uz;

    # SSL certificates (use Let's Encrypt)
    ssl_certificate /etc/letsencrypt/live/sushimei.uz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/sushimei.uz/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    # Modern SSL configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    # HSTS
    add_header Strict-Transport-Security "max-age=63072000" always;

    location / {
        proxy_pass http://customer_app;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}

